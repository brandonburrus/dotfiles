{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "share": "disabled",
  "mcp": {
    "cog": {
      "enabled": true,
      "type": "local",
      "command": ["cog"],
    },
  },
  "skills": {
    "paths": [
      "~/.copilot/skills"
    ]
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py", ".pyi"]
    },
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"]
    },
  },
  "provider": {
    "github-copilot": {
      "models": {
        "claude-haiku-4.5": {
          "limit": { "context": 160000, "output": 32000 }
        },
        "claude-opus-4.5": {
          "limit": { "context": 160000, "output": 32000 }
        },
        "claude-opus-4.6": {
          "limit": { "context": 192000, "output": 64000 }
        },
        "claude-sonnet-4": {
          "limit": { "context": 144000, "output": 16000 }
        },
        "claude-sonnet-4.5": {
          "limit": { "context": 160000, "output": 32000 }
        },
        "claude-sonnet-4.6": {
          "limit": { "context": 160000, "output": 32000 }
        },
        "gemini-2.5-pro": {
          "limit": { "context": 173000, "output": 64000 }
        },
        "gemini-3-flash-preview": {
          "limit": { "context": 173000, "output": 64000 }
        },
        "gemini-3-pro-preview": {
          "limit": { "context": 173000, "output": 64000 }
        },
        "gemini-3.1-pro-preview": {
          "limit": { "context": 173000, "output": 64000 }
        },
        "gpt-4.1": {
          "limit": { "context": 128000, "output": 16384 }
        },
        "gpt-4o": {
          "limit": { "context": 68000, "output": 16384 }
        },
        "gpt-5-mini": {
          "limit": { "context": 192000, "output": 64000 }
        },
        "gpt-5.1": {
          "limit": { "context": 192000, "output": 64000 }
        },
        "gpt-5.1-codex": {
          "limit": { "context": 256000, "output": 128000 }
        },
        "gpt-5.1-codex-max": {
          "limit": { "context": 256000, "output": 128000 }
        },
        "gpt-5.1-codex-mini": {
          "limit": { "context": 256000, "output": 128000 }
        },
        "gpt-5.2": {
          "limit": { "context": 192000, "output": 64000 }
        },
        "gpt-5.2-codex": {
          "limit": { "context": 400000, "output": 128000 }
        },
      },
    },
  },
  "permission": {
    "read": "allow",
    "edit": "ask",
    "write": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "pwd *": "allow",
      "cd *": "allow",
      "echo *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "find *": "allow",
      "glob *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "wc *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git blame *": "allow",
      "git status *": "allow",
      "git branch *": "allow",
      "git tag *": "allow",
      "git remote *": "allow",
      "git stash list *": "allow",
      "git rev-parse *": "allow",
      "which *": "allow",
      "where *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "realpath *": "allow",
      "env *": "allow",
      "printenv *": "allow",
      "type *": "allow",
      "uname *": "allow",
    },
  },
}
