{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "description": "Read-only planning agent — researches the codebase and produces a well-formed implementation plan without making any changes",
      "mode": "primary",
      "color": "#02a7ff",
      "temperature": 0.7,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "websearch": true,
        "question": true,
        "write": false,
        "edit": false,
        "bash": true,
      },
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "rmdir *": "deny",
          "mv *": "deny",
          "sudo *": "deny",
          "git commit*": "deny",
          "git push*": "deny",
          "git merge*": "deny",
          "git rebase*": "deny",
          "git reset*": "deny",
          "git clean*": "deny",
          "npm publish*": "deny",
        },
      },
      "prompt": "You are in READ-ONLY planning mode. NEVER write, edit, delete files, or run state-mutating commands.\n\n## Responsibility\n\nThink, read, search, and build a well-formed plan for the user's goal. Be comprehensive yet concise. Ask clarifying questions and surface tradeoffs. Don't assume — tie loose ends before the user proceeds to implementation.\n\n## Output\n\nA numbered task list. For each step: what will be done, which files are affected, and why (if not obvious). Flag any open questions the user must resolve before implementation begins.",
    },
    "build": {
      "description": "Implementation agent — executes a plan by writing code, editing files, and running build and test commands",
      "mode": "primary",
      "color": "#da0caa",
      "temperature": 0.5,
      "permission": {
        "write": "ask",
        "edit": "ask",
        "bash": {
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "find *": "allow",
          "stat *": "allow",
          "pwd": "allow",
          "which *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "wc *": "allow",
          "git log *": "allow",
          "git diff *": "allow",
          "git show *": "allow",
          "git blame *": "allow",
          "git status *": "allow",
          "git branch *": "allow",
          "git stash list *": "allow",
          "git rev-parse *": "allow",
          "env *": "allow",
          "uname *": "allow",
          "git push --force*": "deny",
          "*": "ask",
        },
      },
      "prompt": "You are an implementation agent. Your job is to execute a plan — write code, edit files, run builds, and verify the result. Follow the plan precisely, make one logical change at a time, and surface any blockers rather than guessing.",
    },
  },
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "share": "disabled",
  "mcp": {
    "cog": {
      "enabled": true,
      "type": "local",
      "command": ["cog"],
    },
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py", ".pyi"]
    },
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"]
    },
  },
  "permission": {
    "read": "allow",
    "edit": "ask",
    "write": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "pwd *": "allow",
      "cd *": "allow",
      "echo *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "find *": "allow",
      "glob *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "wc *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git blame *": "allow",
      "git status *": "allow",
      "git branch *": "allow",
      "git tag *": "allow",
      "git remote *": "allow",
      "git stash list *": "allow",
      "git rev-parse *": "allow",
      "which *": "allow",
      "where *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "realpath *": "allow",
      "env *": "allow",
      "printenv *": "allow",
      "type *": "allow",
      "uname *": "allow",
    },
  },
}
